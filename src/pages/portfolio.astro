---
// src/pages/portfolio.astro
import BaseLayout from "../layouts/BaseLayout.astro";

const business = [
  { img: "lead-the-team.jpg",          alt: "Lead The Team",           href: "https://www.youtube.com/@benfanning1" },
  { img: "leaders-in-logistics.jpg",   alt: "Leaders in Logistics",    href: "https://open.spotify.com/show/16vakhfYmGthnPUKnXjy14" },
  { img: "fueling-ai.jpg",             alt: "Fueling AI",              href: "https://open.spotify.com/show/1DvROV2XiGWi68oaOkOlAF" },
  { img: "ceo-tech-live.jpg",          alt: "CEO Tech Live",           href: "https://open.spotify.com/show/7DKfwsTNWXFjHB0i9UkCmt" },
  { img: "fidium.jpg",                 alt: "Fidium",                  href: "https://www.youtube.com/@Fidium" },
  { img: "dell-podcast.jpg",           alt: "Dell Podcast",            href: "#" },
  { img: "lead-it.jpg",               alt: "Lead I.T",                href: "https://open.spotify.com/show/2cmunRCS0lGOSg4kdxuoOR" },
  { img: "the-cyber-elite.jpg",        alt: "The Cyber Elite",         href: "#" },
  { img: "tql-podcast.jpg",            alt: "TQL Podcast",             href: "#" },
  { img: "tfr.jpg",                    alt: "The Full Ratchet",        href: "https://www.youtube.com/@nicholasmoran3095" },
  { img: "valor-impact.jpg",           alt: "Valor Impact Podcast",    href: "https://open.spotify.com/show/3CbZLYBc5vWPuRv0fW07fp" },
  { img: "opportunity-made.jpg",       alt: "Opportunity Made",        href: "https://open.spotify.com/show/0EeVInnp62Eg0FBuh0cGzg" },
];

const entertainment = [
  { img: "americana-curious.jpg",      alt: "Americana Curious",       href: "https://www.youtube.com/@AmericanaCurious" },
  { img: "zeitgeist.jpg",             alt: "Zeitgeist",               href: "https://www.youtube.com/@zeitgeistpod" },
  { img: "gents-talk.jpg",            alt: "Gents Talk",              href: "https://www.youtube.com/@GentsTalkPodcast" },
  { img: "the-authentic-man.jpg",     alt: "The Authentic Man",       href: "https://www.youtube.com/@TheAuthenticMan" },
  { img: "the-asapark-podcast.jpg",   alt: "The AsaPark Podcast",     href: "https://www.youtube.com/@theasaparkpod" },
  { img: "vda.jpg",                   alt: "VDA",                     href: "https://www.youtube.com/@VeteranDebtAssistance/videos" },
  { img: "sex-upgraded.jpg",          alt: "Sex Upgraded",            href: "https://www.youtube.com/@taylorclarkjohnson" },
  { img: "the-markoruta-exchanges.jpg", alt: "The MarkoRuta Exchanges", href: "https://www.youtube.com/@marcorutaexchangespodcast" },
  { img: "whiskey-noobs.jpg",         alt: "Whiskey Noobs",           href: "https://www.youtube.com/@whiskey_noobs/podcasts" },
  { img: "you-in-yours.jpg",          alt: "You in Yours",            href: "https://www.youtube.com/@youatyours/videos" },
  { img: "passionate-few.jpg",        alt: "Passionate Few",          href: "https://www.youtube.com/@thepassionatefew/podcasts" },
  { img: "the-boys-toilets.jpg",      alt: "The Boys Toilets",        href: "https://www.youtube.com/@TheBoysToiletsPodcast/videos" },
];
---

<BaseLayout
  title="Portfolio"
  description="Sherpa Media's portfolio of business and entertainment podcasts."
>
  <section class="section" style="padding-top:140px">
    <div class="container">
      <p class="kicker">Portfolio</p>
      <h1 class="subpage-title">What we've worked on:</h1>
      <p class="port-lead">Sherpa Media have built a strong portfolio of both Business and Entertainment sectors</p>

      <h2 class="port-h2">Business</h2>
      <div class="pod-grid" role="list" aria-label="Business podcasts">
        {business.map((p) => (
          <a
            class="pod-card"
            role="listitem"
            href={p.href}
            target={p.href === "#" ? undefined : "_blank"}
            rel={p.href === "#" ? undefined : "noopener"}
            aria-label={`Open ${p.alt}`}
          >
            <img src={`/assets/img/podcasts/${p.img}`} alt={`${p.alt} podcast artwork`} loading="lazy" decoding="async" />
            <span class="play" aria-hidden="true"></span>
          </a>
        ))}
      </div>

      <div style="height:56px"></div>

      <h2 class="port-h2">Entertainment</h2>
      <div class="pod-grid" role="list" aria-label="Entertainment podcasts">
        {entertainment.map((p) => (
          <a
            class="pod-card"
            role="listitem"
            href={p.href}
            target="_blank"
            rel="noopener"
            aria-label={`Open ${p.alt}`}
          >
            <img src={`/assets/img/podcasts/${p.img}`} alt={`${p.alt} podcast artwork`} loading="lazy" decoding="async" />
            <span class="play" aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .port-lead { max-width: 820px; color: #ebebed; opacity: .95; line-height: 1.7; margin: 0 0 34px; }
  .port-h2 { margin: 0 0 18px; font-size: 22px; font-weight: 900; letter-spacing: .02em; }

  .pod-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  @media (min-width: 768px) { .pod-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (min-width: 1100px) { .pod-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .pod-card {
    position: relative; display: block; border-radius: 14px; overflow: hidden;
    aspect-ratio: 1/1; background: rgba(255,255,255,.04);
    box-shadow: 0 18px 40px rgba(0,0,0,.22); outline: none;
  }
  .pod-card img { width: 100%; height: 100%; object-fit: cover; display: block; transform: scale(1.01); }

  .pod-card::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,.30) 100%);
    opacity: 0; transition: opacity .18s ease;
  }
  .play {
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%,-50%) scale(.94);
    width: 64px; height: 64px; border-radius: 999px;
    background: rgba(0,0,0,.55); border: 2px solid rgba(255,255,255,.75);
    box-shadow: 0 10px 30px rgba(0,0,0,.35);
    opacity: 0; transition: opacity .18s ease, transform .18s ease;
  }
  .play::before {
    content: ""; position: absolute; left: 50%; top: 50%;
    transform: translate(-38%,-50%);
    width: 0; height: 0;
    border-top: 10px solid transparent; border-bottom: 10px solid transparent;
    border-left: 16px solid rgba(255,255,255,.92);
  }
  @media (hover: hover) {
    .pod-card:hover::after { opacity: 1; }
    .pod-card:hover .play { opacity: 1; transform: translate(-50%,-50%) scale(1); }
  }
  .pod-card:focus-visible::after { opacity: 1; }
  .pod-card:focus-visible .play { opacity: 1; transform: translate(-50%,-50%) scale(1); }
</style>
