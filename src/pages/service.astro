---
// src/pages/service.astro
import BaseLayout from "../layouts/BaseLayout.astro";
const calendlyUrl = "https://calendly.com/production-sherpamedia/30min";

const steps = [
  {
    num: "Step 1",
    title: "Discovery",
    body: "We dive deep into your business, brand, and existing content to understand what is working, what is not, and who your ideal audience is. Using these insights, we identify opportunities to create content that truly resonates and attracts the right prospects.",
  },
  {
    num: "Step 2",
    title: "Strategy & Solution",
    body: "Based on our research, we develop a tailored content plan that outlines the key pieces you need and how to leverage them for maximum impact, turning your content into a structured, audience-targeted lead magnet. As part of this, we also define the scope of our work and provide clear pricing.",
  },
  {
    num: "Step 3",
    title: "Content Creation",
    body: "With the strategy in place, we help you record and produce each piece, then handle all post-production editing. Every asset is polished, on-brand, and optimized to engage your audience across the channels that matter most.",
  },
];
---

<BaseLayout
  title="Service"
  description="A clear 3-step content system: Discovery, Strategy, and Content Creation by Sherpa Media."
>
  <section class="services-page">
    <div class="container">
      <header class="services-hero">
        <p class="kicker">Service</p>
        <h1 class="subpage-title">A Clear 3-Step Content System</h1>
        <p class="services-subtitle">
          We turn your content workflow into a structured lead engine from audience insight to polished, channel-ready assets.
        </p>
      </header>

      <div class="service-steps" role="list" aria-label="Service process">
        {steps.map((step) => (
          <article class="service-step" role="listitem">
            <p class="service-step__num">{step.num}</p>
            <h2 class="service-step__title">{step.title}</h2>
            <p class="service-step__copy">{step.body}</p>
          </article>
        ))}
      </div>

      <section class="service-cta" aria-label="Book a call">
        <h2 class="service-cta__title">Ready to build your content engine?</h2>
        <a class="btn" href={calendlyUrl} target="_blank" rel="noopener">BOOK A CALL</a>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .services-page {
    padding-top: 140px; padding-bottom: 90px; position: relative;
  }
  .services-page::before {
    content: "";
    position: absolute; inset: 0 0 auto 0; height: 420px;
    background:
      radial-gradient(760px 260px at 16% 0%, rgba(23,113,255,.30), rgba(23,113,255,0) 70%),
      radial-gradient(560px 260px at 86% 0%, rgba(23,113,255,.24), rgba(23,113,255,0) 70%);
    pointer-events: none;
  }
  .services-page .container { position: relative; z-index: 1; }

  .services-hero { max-width: 840px; margin-bottom: 38px; }
  .services-subtitle { margin: 0; color: #ebebed; opacity: .9; max-width: 760px; line-height: 1.7; font-size: 17px; }
  @media (max-width: 700px) { .services-subtitle { font-size: 16px; } }

  .service-steps { display: grid; grid-template-columns: 1fr; gap: 18px; }
  @media (min-width: 920px) { .service-steps { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 22px; } }

  .service-step {
    position: relative;
    border: 1px solid rgba(255,255,255,.10);
    border-radius: 14px; padding: 26px 24px 24px;
    background: linear-gradient(160deg, rgba(18,43,87,.58), rgba(7,18,39,.88));
    box-shadow: 0 20px 42px rgba(0,0,0,.26);
  }
  @media (min-width: 920px) { .service-step { min-height: 100%; } }

  .service-step__num { margin: 0 0 10px; color: #91bcff; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; font-size: 12px; }
  .service-step__title { margin: 0 0 12px; font-size: 28px; line-height: 1.1; font-weight: 900; }
  @media (max-width: 700px) { .service-step__title { font-size: 24px; } }
  .service-step__copy { margin: 0; color: #e8edf9; opacity: .95; line-height: 1.72; }

  .service-cta {
    margin-top: 28px; display: flex; gap: 16px; align-items: center;
    justify-content: space-between; flex-wrap: wrap;
    padding: 22px 24px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,.12);
    background: rgba(12,31,64,.75);
  }
  .service-cta__title { margin: 0; font-size: 22px; font-weight: 900; }
</style>
