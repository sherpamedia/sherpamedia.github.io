---
// src/pages/about.astro
import BaseLayout from "../layouts/BaseLayout.astro";
const calendlyUrl = "https://calendly.com/production-sherpamedia/30min";
---

<BaseLayout
  title="About"
  description="Sherpa Media guides brands to new heights through strategy, content, and podcast production."
>
  <section class="about-page">
    <div class="container">
      <div class="about-hero">
        <p class="kicker">About</p>
        <h1 class="subpage-title">About Sherpa Media</h1>
        <p class="about-hero__lead">
          We believe in hard work, dedication, and going all in to achieve meaningful results.
        </p>
      </div>

      <div class="about-block">
        <p>
          At Sherpa Media, our name reflects how we work with our clients. Just like a sherpa
          guides climbers to the summit through preparation, resilience, and relentless support,
          we believe in hard work, dedication, and going all in to achieve meaningful results.
          Our mission is to elevate brands to new heights, helping them navigate their content
          journey with clarity, strategy, and a team committed to reaching the summit together.
        </p>
        <p>
          Whether you're a company with an internal or external podcast, or a coach or creator
          using your podcast as a magnet for new clients, we ensure every episode works harder
          for your business. Our expertise turns conversations into content that resonates,
          engages, and converts.
        </p>
        <p>
          We're proud to partner with industry leaders, helping them amplify their voice, drive
          meaningful engagement, and achieve measurable results. With Sherpa Media, your podcast
          becomes more than a show — it becomes a strategic marketing tool that grows your brand.
        </p>
      </div>

      <div class="about-block">
        <h2>Mission</h2>
        <p>
          Our mission is to unlock the full potential of every voice, helping businesses and
          creators share their message with audiences they've only dreamed of reaching. We
          strive to turn podcasts into powerful catalysts for growth, connection, and impact,
          amplifying ideas that inspire, engage, and transform.
        </p>
      </div>

      <div class="service-cta" style="margin-top:0">
        <h2 class="service-cta__title">Carry your story further</h2>
        <a class="btn" href={calendlyUrl} target="_blank" rel="noopener">BOOK A CALL</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page { padding-top: 140px; padding-bottom: 90px; position: relative; }
  .about-page::before {
    content: "";
    position: absolute; inset: 0 0 auto 0; height: 420px;
    background:
      radial-gradient(760px 260px at 16% 0%, rgba(23,113,255,.25), rgba(23,113,255,0) 70%),
      radial-gradient(560px 260px at 86% 0%, rgba(23,113,255,.20), rgba(23,113,255,0) 70%);
    pointer-events: none;
  }
  .about-page .container { position: relative; z-index: 1; }

  .about-hero { max-width: 900px; margin-bottom: 56px; }
  .about-hero__lead { font-size: 20px; line-height: 1.6; color: #ebebed; opacity: .95; max-width: 720px; margin: 0; }

  .about-block { max-width: 860px; margin-bottom: 56px; }
  .about-block h2 { margin: 0 0 16px; font-size: 28px; font-weight: 900; letter-spacing: -0.01em; }
  .about-block p { margin: 0 0 14px; line-height: 1.7; color: #ebebed; opacity: .92; }

  .service-cta {
    max-width: 860px; margin-top: 28px;
    display: flex; gap: 16px; align-items: center;
    justify-content: space-between; flex-wrap: wrap;
    padding: 22px 24px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,.12);
    background: rgba(12,31,64,.75);
  }
  .service-cta__title { margin: 0; font-size: 22px; font-weight: 900; }
</style>
